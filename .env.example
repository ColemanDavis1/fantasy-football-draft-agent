# Copy to .env and fill in on draft day. Nothing here is required to refresh data;
# the ESPN league fields are only needed when you read/track a specific league.

# --- ESPN league (provided on draft day; the tool is league-agnostic until then) ---
# Find the number in your league URL: .../league?leagueId=123456
ESPN_LEAGUE_ID=
# NFL season the draft belongs to (defaults to the current year if blank).
ESPN_SEASON=
# Which team in the league is YOU (optional). If blank, the CLI prints all teams
# so you can pick your team_id. Needed to compute "my draft slot" and my roster.
MY_TEAM_ID=

# --- Private-league auth (ONLY if your league is private) ---
# Grab these two cookies from your logged-in ESPN browser session. You handle the
# login; this tool never sees your password. Leave blank for public leagues.
ESPN_SWID=
ESPN_S2=

# --- Anthropic API (used in Phase 3+ for on-the-clock reasoning) ---
# Read from env only; never hardcoded. Leave blank to run in no-LLM mode.
ANTHROPIC_API_KEY=

# --- Optional overrides ---
# DRAFT_DB_PATH=backend/draft.db
